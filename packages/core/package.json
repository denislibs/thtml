{
  "name": "@thtml/core",
  "version": "0.1.1",
  "description": "Core HTML template engine for thtml",
  "license": "MIT",
  "author": "thtml contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/denislibs/thtml",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/denislibs/thtml/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/denislibs/thtml/issues"
  },
  "keywords": ["html", "template", "template-engine", "typescript", "thtml"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --sourcemap --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
